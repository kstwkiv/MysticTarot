{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "JWT_SECRET": "your-super-secret-jwt-key-at-least-32-chars",
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "bookings-route": {
        "ClusterId": "booking-cluster",
        "Match": {
          "Path": "/api/bookings/{**catch-all}"
        }
      },
      "readings-route": {
        "ClusterId": "reading-cluster",
        "Match": {
          "Path": "/api/readings/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity-destination": {
            "Address": "http://identity-service:5001"
          }
        }
      },
      "booking-cluster": {
        "Destinations": {
          "booking-destination": {
            "Address": "http://booking-service:5002"
          }
        }
      },
      "reading-cluster": {
        "Destinations": {
          "reading-destination": {
            "Address": "http://reading-service:5003"
          }
        }
      }
    }
  }
}
